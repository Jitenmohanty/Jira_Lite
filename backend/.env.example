# Copy to .env and fill in. Never commit .env.
NODE_ENV=development
PORT=4000

# Postgres connection (added in Stage 1). With docker-compose this is:
DATABASE_URL=postgres://tracer:tracer@localhost:5432/tracer

# Auth (Stage 2)
JWT_SECRET=replace-with-a-long-random-string

# CORS — the frontend origin allowed to send credentialed requests.
CORS_ORIGIN=http://localhost:3000

# Public URL of the frontend (used to build links in emails).
APP_URL=http://localhost:3000

# Redis — BullMQ queues + workers. rediss:// for TLS (managed Redis).
REDIS_URL=redis://localhost:6379

# Transactional email (optional in dev — without any transport, emails are
# rendered and logged instead of delivered). Two transports, Resend preferred:
#
# 1) Resend (recommended) — set RESEND_API_KEY (resend.com/api-keys). EMAIL_FROM
#    must use a Resend-verified domain, or onboarding@resend.dev for testing
#    (which delivers only to your Resend account address; delivered@resend.dev
#    is a safe always-accepted test recipient).
RESEND_API_KEY=
# 2) SMTP (fallback) — e.g. Gmail with an App Password:
#    SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_USER=you@gmail.com  SMTP_PASS=<app-password>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Tracer <onboarding@resend.dev>

# Google OAuth (optional — enables "Continue with Google"). Create an OAuth 2.0
# Client (Web) at console.cloud.google.com, add the redirect URI below, then set:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# "Ask Tracer" AI assistant (optional). Semantic search uses a LOCAL embedding
# model (no key, no cost), so retrieval works without this. Set a Gemini key to
# enable the answering agent. Get one FREE at https://aistudio.google.com/apikey
# NOTE: the DB must have the pgvector extension — the docker-compose db image
# (pgvector/pgvector) and Neon both provide it; the migration enables it.
GEMINI_API_KEY=
# Optional overrides (sensible defaults otherwise):
# AI_MODEL=gemini-2.5-flash
# AI_MAX_TOKENS=1024
# AI_MAX_TOOL_ITERATIONS=6
# AI_RATE_LIMIT=20
# AI_RATE_WINDOW_MS=3600000
