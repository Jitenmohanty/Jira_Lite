# Copy to .env and fill in. Never commit .env.
NODE_ENV=development
PORT=4000

# Postgres connection (added in Stage 1). With docker-compose this is:
DATABASE_URL=postgres://tracer:tracer@localhost:5432/tracer

# Auth (Stage 2)
JWT_SECRET=replace-with-a-long-random-string

# CORS — the frontend origin allowed to send credentialed requests.
CORS_ORIGIN=http://localhost:3000

# Public URL of the frontend (used to build links in emails).
APP_URL=http://localhost:3000

# Redis — BullMQ queues + workers. rediss:// for TLS (managed Redis).
REDIS_URL=redis://localhost:6379

# Transactional email (optional in dev — without it, emails are rendered and
# logged instead of delivered). For Gmail, create an App Password and set:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_USER=you@gmail.com  SMTP_PASS=<app-password>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Tracer <no-reply@tracer.dev>
